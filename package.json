{
  "name": "lintmax",
  "version": "0.0.3",
  "description": "Maximum strictness linting, formatting, and type-checking in one package",
  "keywords": [
    "biome",
    "eslint",
    "formatter",
    "lint",
    "linter",
    "oxlint",
    "prettier",
    "typecheck",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/1qh/lintmax"
  },
  "license": "MIT",
  "author": "1qh",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./eslint": {
      "types": "./dist/eslint.d.ts",
      "import": "./dist/eslint.js"
    },
    "./tsconfig": "./tsconfig.json",
    "./tsconfig.json": "./tsconfig.json"
  },
  "bin": {
    "lintmax": "dist/cli.js"
  },
  "files": [
    "dist",
    "tsconfig.json",
    "oxlintrc.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && printf '#!/usr/bin/env bun\\n' | cat - dist/cli.js > dist/cli.tmp && mv dist/cli.tmp dist/cli.js && chmod +x dist/cli.js",
    "check": "bun dist/cli.js check",
    "fix": "bun dist/cli.js fix",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@biomejs/biome": "latest",
    "@eslint-react/eslint-plugin": "latest",
    "@eslint/compat": "latest",
    "@eslint/js": "latest",
    "@next/eslint-plugin-next": "latest",
    "eslint": "9",
    "eslint-plugin-better-tailwindcss": "latest",
    "eslint-plugin-perfectionist": "latest",
    "eslint-plugin-prefer-arrow-functions": "latest",
    "eslint-plugin-react": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-turbo": "latest",
    "oxlint": "latest",
    "prettier": "latest",
    "sort-package-json": "latest",
    "typescript-eslint": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "typescript": ">=5"
  }
}
